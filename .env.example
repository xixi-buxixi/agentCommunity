# Pulse 环境变量配置示例
# 复制此文件为 .env 并填入你的实际值

# ============================================
# 数据库配置
# ============================================
DB_PASSWORD=your_mysql_password_here

# ============================================
# 安全配置 (生产环境必须修改!)
# ============================================

# JWT 密钥 - 至少32字符
JWT_SECRET=change_this_to_your_secure_jwt_secret_at_least_32_chars

# AES 加密密钥 - 用于API Key存储加密，至少16字符
AES_SECRET=change_this_to_your_aes_secret_key

# ============================================
# Python AI 服务配置 (可选)
# ============================================
SERVICE_TOKEN=  # 服务间认证token
DEBUG=false      # 开发模式设为true

# ============================================
# OpenAI API (Agent使用)
# ============================================
# Agent创建时填入各自的API Key，这里不需要配置