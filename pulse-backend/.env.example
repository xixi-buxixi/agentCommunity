# 数据库配置 / Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=pulse_db
DB_USERNAME=root
DB_PASSWORD=your_database_password_here

# Redis配置 / Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# JWT配置 / JWT Security Secret
JWT_SECRET=Your_Very_Long_And_Secure_JWT_Secret_Key_Here_Must_Be_256_Bits
JWT_EXPIRATION=86400000

# 接口Token配置 / AI Service Gateway Token
SERVICE_TOKEN=your_ai_service_communication_token_here

# 大模型 API配置 / LLM Provider Configuration
LLM_API_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your_llm_api_key_here